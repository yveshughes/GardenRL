{
  "name": "gardenrl-gpu-training",
  "description": "GPU training service for GardenRL",
  "projectId": "hackathon",
  "billing": {
    "deploymentPlan": "nf-gpu-hack-16-64"
  },
  "deployment": {
    "instances": 1,
    "docker": {
      "configType": "default",
      "image": "ubuntu:22.04",
      "cmd": ["sleep", "infinity"]
    },
    "gpu": {
      "enabled": true,
      "type": "h100-80",
      "count": 1
    },
    "storage": {
      "ssd": 30
    },
    "resources": {
      "cpu": 4000,
      "memory": 16384
    },
    "regionId": "meta-openenv"
  },
  "ports": []
}
